# 업비트 API 키 설정
# https://upbit.com/mypage/open_api_management 에서 발급받으세요

UPBIT_ACCESS_KEY=your_access_key_here
UPBIT_SECRET_KEY=your_secret_key_here

# 해외 거래소 API 키 (바이낸스 OR OKX 중 하나만 있어도 됨)
# 바이낸스 (선택사항)
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET_KEY=your_secret_key_here

# OKX (선택사항) - 바이낸스 대신 사용 가능
OKX_API_KEY=your_api_key_here
OKX_SECRET_KEY=your_secret_key_here
OKX_PASSPHRASE=your_passphrase_here

# 빗썸 API 키 (선택사항)
BITHUMB_API_KEY=your_api_key_here
BITHUMB_SECRET_KEY=your_secret_key_here

# 거래 설정
MIN_PROFIT_RATE=1.5           # 최소 수익률 (%)
MAX_TRADE_AMOUNT_KRW=100000   # 1회 최대 거래 금액 (원)
MAX_DAILY_TRADES=10           # 일일 최대 거래 횟수
